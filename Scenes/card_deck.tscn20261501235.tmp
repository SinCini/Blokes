[sub_resource type="GDScript" id="GDScript_bhann"]
resource_name = "CardDeckScirpt"
script/source = "extends Node2D
class_name Deck
@export var card_scene: PackedScene
#var pointValue = 0
#var timeValue = 0
#var usesPoints = false
#var changesTime = false
#var setsTime = false
var cardNames = [\"StepNephew\",\"SidewaysLance\",\"McFondals\",\"Grant\", \"Nate to the Party\", \"The Chief\", \"Bill Doorstop\",\"The Minister\", \"The twins\", \"Tammy Tip Toe\",
				\"Smedward\", \"Cliff\", \"Wincent\", \"Flimber Wimber\", \"Almonds\", \"The Squares\",\"Mr. Stop\", \"Idris Elba\", \"Hot Sauce Mumbango\", \"Doctor Mushroom\",
				\"Goblin Time\", \"Oh...Oh God\", \"Orsen Wells\", \"Heterosecual Jester\", \"Uncle Bacon\", \"No\", \"No 2\", \"Nei's a Deal\", \"Investin' Bendan\", \"I'm In\", 
				\"What?\", \"Steven Glockenspielberg\", \"5 Cans of 7Down\", \"Chelsea Football Club\", \"Paul\", \"Donna's Kebab\", \"Bones MC. Skeleton\", \"Scooby Don't\", \"Scambadi Lameeni\", \"Coin\", 
				\"Crease Pirate\", \"Cool Ghosts\", \"Idea Guy\", \"Danewinntendo Direct\", \"The Nonce is here\"]
var pointValues = [0,0,0,0,0,0,1,2,3,4,
				4,5,5,10,10,1,1,1,0,2,
				2,2,0,0,0,0,3,0,0,0,
				2,0,7,0,0,1,10,2,3,4,
				5,8,5,4,0]
var timeValues = [120,180,240,300,360,600,240,180,180,300,
				360,180,600,120,600,120,300,480,2,0,
				0,2,0,0.5,120,0,0,0,0,
				0,0,0.5,300,-120,60,-300,60,0,0,0,
				0,0,0,0,0]
var changeTimeBool = [true,true,true,true,true,true,true,true,true,true,
					true,true,true,true,true,true,true,true,false,false,
					false,true,false,false,false,false,false,false,false,false,
					false,false,true,true,false,true,false,false,false,false,
					false,false,false,false,false]
var setTimeBool = [false,false,false,false, false, false, false, false, false, false, 
				false, false, false, false, false, false, false, false, true, false,
				false, false, false, true,true, false, false, false, false, false, 
				false,true, false, false,true, false, false, false, false, false,
				false, false, false, false, false]
var useD6 = [false, false,false, false, false, false, false, false, false, false,
			false, false, false, false, false, false, false, false, false, false,
			true, true, false, false, false, false, false, false, false, false,
			true, false, false, false, false, false, false, false, false, false,
			false, false, false, false, false]
var CardsInDeck = []
var CardsInDiscard = []
# Called when the node enters the scene tree for the first time.
func _ready():
	FillDeck()
	ShuffleDeck()
	pass # Replace with function body.
func FillDeck():
	var newCard
	for i in range(cardNames.size()):
		newCard = card_scene.instantiate()
		newCard.SetValues(cardNames[i], pointValues[i], timeValues[i],changeTimeBool[i],setTimeBool[i],useD6[i])
		newCard.name = newCard.GetCardName()
		add_child(newCard, true)
		newCard.SetSprite(i%10, i/10)
		CardsInDeck.append(newCard)
		newCard.position = $Deck.position
	SetDeckText()
func ShuffleDeck():
	CardsInDeck.shuffle()
@rpc(\"any_peer\")
func DrawFunction():
	pass
@rpc(\"any_peer\")
func DrawForAll(playerID, cardName, playerObject, playerHand, handSize):
	if(multiplayer.get_unique_id() == playerID):
		var cardPosition = FindCard(cardName)
		var currentCard = CardsInDeck[cardPosition]
		CardsInDeck.remove_at(cardPosition)
		remove_child(currentCard)
		if(CardsInDeck.size() == 0):
			RefillDeck()
		SetDeckText()
		#var handPosition = playerObject/$hand.global_position
		#handPosition += (handSize * Vector2(100, 0))
		playerObject.add_child(currentCard)
		playerHand.append(currentCard)
		currentCard.show()
		#currentCard.set_position(handPosition)
		#currentCard.SetActive(true)
@rpc(\"any_peer\")
func Discard(card):
	var cardName = card.GetCardName()
	add_child(card)
	if(cardName == \"Neil's a Deal\" || cardName == \"Investin' Bendan\"):
		card.queue_free()
	else:	
		CardsInDiscard.append(card)
		card.SetActive(false)
		SetDiscardText()
		card.position = $Discard.position
func SetDeckText():
	$DeckText.set_text(\"Deck: \" + str(CardsInDeck.size()))
func SetDiscardText():
	$DiscardText.set_text(\"Discard: \" + str(CardsInDiscard.size()))
@rpc(\"any_peer\")
func RefillDeck():
	while(!CardsInDiscard.is_empty()):
		CardsInDeck.append(CardsInDiscard.pop_front())
	SetDiscardText()
	ShuffleDeck()	
func GetTopCard():
	return CardsInDeck.front().GetCardName()
func FindCard(cardName):
	for i in range(CardsInDeck.size()):
		if(CardsInDeck[i].GetCardName() == cardName):
			return i
"

