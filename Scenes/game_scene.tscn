[sub_resource type="GDScript" id="GDScript_d4mfh"]
script/source = "extends Node
class_name gameScript
@export var Player: PackedScene
@export var card_deck: PackedScene
var LobbySize 
var playersInGame = []
var winner = null
var cardDeck
var lastBlokePlayed = null
# Called when the node enters the scene tree for the first time.
func _ready():
	cardDeck = card_deck.instantiate()
	add_child(cardDeck)
	$GameTimer.one_shot = true

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta):
	pass
func GameOver():
	var localWinner = -1
	var localScore = -1
	var tempScore
	for i in range(playersInGame.size()):
		tempScore = playersInGame[i].GetScore()
		if(tempScore > localScore):
			localWinner = i
			localScore = tempScore
	return localWinner
func GetDeck():
	return cardDeck
func SetLastBlokePlayed(card):
	lastBlokePlayed = card
func _on_game_timer_timeout():
	GameOver()
func _on_player_idletimer_timeout():
	pass # Replace with function body.
func GetGameTime():
	return $GameTimer.get_time_left()
func GetGameTimer():
	return $GameTimer
func AddPlayer():
	var newPlayer = Player.instantiate()
	newPlayer.SetPlayerID(playersInGame.size())
	playersInGame.append(newPlayer)
"

